# ============================================
# STEMViz - 豆包大模型配置
# ============================================

# 豆包 LLM + 多模态（火山方舟）
# API Key 获取: https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型配置
REASONING_MODEL=doubao-seed-2-1-pro-260628
MULTIMODAL_MODEL=doubao-seed-2-1-pro-260628

# 豆包 TTS（语音合成）
# API Key 获取: https://console.volcengine.com/speech
DOUBAO_TTS_API_KEY=your_doubao_tts_api_key_here
DOUBAO_TTS_RESOURCE_ID=seed-tts-1.0
DOUBAO_TTS_AUTH_MODE=new  # new / old / auto

# 音色设置
DOUBAO_TTS_VOICE_ID=zh_female_shuangkuaisisi_moon_bigtts
DOUBAO_TTS_SPEED_RATIO=0.0
DOUBAO_TTS_VOLUME_RATIO=0.0

ANIMATION_CODE_GEN_CONCURRENCY=1